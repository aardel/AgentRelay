#!/usr/bin/env python3
"""
agent-send - send a command to a peer agentrelay node.

Examples:
    agent-send --list
    agent-send test-bench "install esp-idf v6.1"
    agent-send test-bench --agent codex "fix the failing build in ~/proj"
    agent-send test-bench --auto "uname -a && df -h"
    agent-send test-bench --approve "rm -rf node_modules && npm ci"

The target name must match the `node_name` field on the destination
machine's config (defaults to its hostname).
"""

from __future__ import annotations

import argparse
import asyncio
import json
import socket
import sys
import uuid
from pathlib import Path
from typing import Any

import aiohttp
import yaml
from zeroconf import IPVersion, ServiceStateChange
from zeroconf.asyncio import (AsyncServiceBrowser, AsyncServiceInfo,
                              AsyncZeroconf)

SERVICE_TYPE = "_agentrelay._tcp.local."
DEFAULT_CONFIG = Path.home() / ".config" / "agentrelay" / "config.yaml"


def load_config(config_path: Path) -> dict[str, Any]:
    if not config_path.exists():
        print(f"no config at {config_path}\n"
              f"run: agentrelay --init", file=sys.stderr)
        sys.exit(1)
    data = yaml.safe_load(config_path.read_text())
    if not isinstance(data, dict):
        print("invalid config", file=sys.stderr)
        sys.exit(1)
    return data


def load_token(config_path: Path) -> str:
    data = load_config(config_path)
    token = data.get("token")
    if not token:
        print("no token in config", file=sys.stderr)
        sys.exit(1)
    return token


def parse_target(target: str, agent_option: str | None) -> tuple[str, str | None]:
    """Return (node, agent) from legacy node or new agent@node syntax."""
    if "@" not in target:
        return target, agent_option

    agent, node = target.split("@", 1)
    agent = agent.strip()
    node = node.strip()
    if not agent or not node:
        raise ValueError("target must be agent@node")
    if agent_option and agent_option != agent:
        raise ValueError(
            f"--agent {agent_option} conflicts with target agent {agent}")
    return node, agent


def is_local_target(target: str, cfg: dict[str, Any]) -> bool:
    node_name = cfg.get("node_name") or socket.gethostname().split(".")[0]
    aliases = {"local", "localhost", "self", node_name}
    return target in aliases


def resolve_target_address(
    target: str,
    cfg: dict[str, Any],
    peers: dict[str, tuple[str, int]],
) -> tuple[str, int]:
    if is_local_target(target, cfg):
        return "127.0.0.1", int(cfg.get("port") or 9876)
    return peers[target]


def parse_agents_csv(value: str) -> list[str]:
    return [agent.strip() for agent in value.split(",") if agent.strip()]


async def _resolve(azc: AsyncZeroconf, name: str, results: dict) -> None:
    info = AsyncServiceInfo(SERVICE_TYPE, name)
    if not await info.async_request(azc.zeroconf, 2000):
        return
    node = info.properties.get(b"node", b"").decode() or name.split(".")[0]
    addrs = info.parsed_scoped_addresses()
    if addrs:
        results[node] = (addrs[0], info.port)


async def discover(timeout: float = 2.0) -> dict[str, tuple[str, int]]:
    """Return {node_name: (ip, port)} for every peer seen within timeout."""
    azc = AsyncZeroconf(ip_version=IPVersion.V4Only)
    results: dict[str, tuple[str, int]] = {}

    def handler(zc=None, service_type=None, name=None, state_change=None,
                **kwargs):
        name = name or kwargs.get("name")
        state_change = state_change or kwargs.get("state_change")
        if state_change == ServiceStateChange.Added:
            asyncio.ensure_future(_resolve(azc, name, results))

    browser = AsyncServiceBrowser(azc.zeroconf, [SERVICE_TYPE],
                                   handlers=[handler])
    await asyncio.sleep(timeout)
    await browser.async_cancel()
    await azc.async_close()
    return results


async def discover_from_daemon(cfg: dict[str, Any]) -> dict[str, dict]:
    """Query the local daemon's heartbeat-maintained peer registry.

    Returns {node_name: {"address": str, "port": int, "agents": str}}.
    Fast (no mDNS scan) and includes peers added via /peer-announce heartbeat.
    """
    port = int(cfg.get("port") or 9876)
    token = cfg.get("token", "")
    try:
        timeout = aiohttp.ClientTimeout(total=2)
        async with aiohttp.ClientSession(timeout=timeout) as session:
            async with session.get(
                f"http://127.0.0.1:{port}/peers",
                headers={"X-Agent-Token": token},
            ) as resp:
                data = await resp.json()
        return {
            p["name"]: {"address": p["address"], "port": p["port"],
                        "agents": p.get("agents", "")}
            for p in data.get("peers", [])
        }
    except Exception:
        return {}


async def _fetch_active_sessions(addr: str, port: int, token: str) -> list[str]:
    """Return list of active agent names from a node's /info endpoint."""
    try:
        timeout = aiohttp.ClientTimeout(total=2)
        async with aiohttp.ClientSession(timeout=timeout) as session:
            async with session.get(
                f"http://{addr}:{port}/info",
                headers={"X-Agent-Token": token},
            ) as resp:
                if resp.status == 200:
                    data = await resp.json()
                    return data.get("active_sessions") or []
    except Exception:
        pass
    return []


async def cmd_list(cfg: dict[str, Any] | None = None,
                   self_name: str | None = None) -> int:
    cfg = cfg or {}
    configured_agents = ",".join((cfg.get("adapters") or {}).keys())
    local_name = cfg.get("node_name") or socket.gethostname().split(".")[0]
    local_port = int(cfg.get("port") or 9876)
    token = cfg.get("token", "")

    daemon_peers = await discover_from_daemon(cfg)
    mdns_peers = await discover(timeout=2.5)

    # Build unified peer map: mDNS base, daemon values take priority
    peers: dict[str, tuple[str, int]] = {**mdns_peers}
    peer_agents: dict[str, str] = {}
    for name, info in daemon_peers.items():
        peers[name] = (info["address"], info["port"])
        peer_agents[name] = info["agents"]
    peers[local_name] = ("127.0.0.1", local_port)

    if not peers:
        print("no peers discovered")
        return 1
    me = self_name or socket.gethostname().split(".")[0]

    # Fetch active PTY sessions from all nodes in parallel
    node_list = sorted(peers.keys())
    active_results = await asyncio.gather(
        *[_fetch_active_sessions(peers[n][0], peers[n][1], token) for n in node_list],
        return_exceptions=True,
    )
    active_by_node: dict[str, list[str]] = {
        node: (res if isinstance(res, list) else [])
        for node, res in zip(node_list, active_results)
    }

    print(f"{'node':<20}  {'address':<16}  {'port':<6}  {'agents (configured)':<36}  {'active (running)':<24}  self?")
    print(f"{'-' * 20}  {'-' * 16}  {'-' * 6}  {'-' * 36}  {'-' * 24}  -----")
    for node in node_list:
        addr, port = peers[node]
        marker = "*" if node == me else ""
        agents = configured_agents if node == me else peer_agents.get(node, "")
        active = ",".join(active_by_node.get(node) or [])
        print(f"{node:<20}  {addr:<16}  {port:<6}  {agents:<36}  {active:<24}  {marker}")
    return 0


async def cmd_broadcast(token: str, message: str, agent: str | None,
                        self_name: str | None = None,
                        cfg: dict[str, Any] | None = None) -> int:
    """Send message to all discovered peers in parallel — fire and forget."""
    daemon_peers = await discover_from_daemon(cfg or {})
    peers: dict[str, tuple[str, int]] = {
        name: (info["address"], info["port"])
        for name, info in daemon_peers.items()
    }
    if not peers:
        peers = await discover(timeout=2.5)
    me = self_name or socket.gethostname().split(".")[0]
    targets = {name: addr for name, addr in peers.items() if name != me}
    if not targets:
        print("no peers discovered to broadcast to", file=sys.stderr)
        return 1

    timeout = aiohttp.ClientTimeout(total=None, sock_connect=5)

    async def _post_one(name: str, addr: str, port: int) -> dict:
        payload: dict = {
            "task": message,
            "agents": [{"node": name, "agent": agent or "claude"}],
            "coordinator_agent": None,
            "mode": "parallel",
        }
        async with aiohttp.ClientSession(timeout=timeout) as session:
            try:
                async with session.post(
                    f"http://{addr}:{port}/coordinate",
                    json=payload,
                    headers={"X-Agent-Token": token},
                ) as resp:
                    data = await resp.json()
                return {"node": name, "ok": True, "data": data}
            except aiohttp.ClientError as e:
                return {"node": name, "ok": False, "error": str(e)}

    results = await asyncio.gather(
        *[_post_one(name, addr, port) for name, (addr, port) in targets.items()]
    )
    print(json.dumps(list(results), indent=2))
    return 0 if all(r["ok"] for r in results) else 1


async def cmd_coordinate_local(
    token: str,
    message: str,
    agents: list[str],
    coordinator_agent: str | None,
    mode: str,
    cfg: dict[str, Any],
) -> int:
    node_name = cfg.get("node_name") or socket.gethostname().split(".")[0]
    port = int(cfg.get("port") or 9876)
    payload = {
        "task": message,
        "agents": [{"node": node_name, "agent": agent} for agent in agents],
        "coordinator_agent": coordinator_agent,
        "mode": mode,
    }
    timeout = aiohttp.ClientTimeout(total=None, sock_connect=5)
    async with aiohttp.ClientSession(timeout=timeout) as session:
        try:
            async with session.post(
                f"http://127.0.0.1:{port}/coordinate",
                json=payload,
                headers={"X-Agent-Token": token},
            ) as resp:
                data = await resp.json()
        except aiohttp.ClientError as e:
            print(f"request failed: {e}", file=sys.stderr)
            return 1

    print(json.dumps(data, indent=2))
    return 0 if "error" not in data else 1


async def cmd_send(token: str, target: str, command: str,
                   agent: str | None, policy_hint: str | None,
                   cfg: dict[str, Any] | None = None,
                   self_name: str | None = None,
                   profile: str | None = None) -> int:
    cfg = cfg or {}
    # Use daemon registry first (instant, heartbeat-maintained); fall back to mDNS
    daemon_peers = await discover_from_daemon(cfg)
    peers: dict[str, tuple[str, int]] = {
        name: (info["address"], info["port"])
        for name, info in daemon_peers.items()
    }
    if target not in peers and not is_local_target(target, cfg):
        peers = await discover(timeout=2.5)
    if target not in peers and not is_local_target(target, cfg):
        print(f"peer not found: {target}", file=sys.stderr)
        if peers:
            print(f"available: {', '.join(sorted(peers))}", file=sys.stderr)
        else:
            print("no peers discovered on the LAN", file=sys.stderr)
        return 1
    addr, port = resolve_target_address(target, cfg, peers)

    if not is_local_target(target, cfg):
        from agentrelay import Config
        from relay_client import deliver_to_peer
        from task_queue import TaskQueue

        node_name = self_name or cfg.get("node_name") or socket.gethostname().split(".")[0]
        tq = TaskQueue()
        task_id = await tq.create(
            source_node=node_name,
            target_node=target,
            target_agent=agent or cfg.get("default_agent") or "claude",
            message=command,
            status="queued",
            permission_profile=profile or "safe",
        )

        ok, msg = deliver_to_peer(
            Config.load_dict(cfg), addr, port, command, agent,
            task_id=task_id,
        )

        await tq.update_status(task_id, "sent" if ok else "failed",
                               error=None if ok else msg)
        print(json.dumps(
            {"ok": ok, "message": msg, "task_id": task_id, "delivery": "auto"}, indent=2))
        return 0 if ok else 1

    url = f"http://{addr}:{port}/dispatch"
    payload: dict = {
        "from": self_name or socket.gethostname().split(".")[0],
        "command": command,
        "request_id": uuid.uuid4().hex,
    }
    if agent:
        payload["agent"] = agent
    if policy_hint:
        payload["policy_hint"] = policy_hint

    timeout = aiohttp.ClientTimeout(total=None, sock_connect=5)
    async with aiohttp.ClientSession(timeout=timeout) as session:
        try:
            async with session.post(
                url, json=payload,
                headers={"X-Agent-Token": token},
            ) as resp:
                data = await resp.json()
        except aiohttp.ClientError as e:
            print(f"request failed: {e}", file=sys.stderr)
            return 1

    print(json.dumps(data, indent=2))
    return 0 if data.get("exit_code", 1) == 0 else 1


def main() -> None:
    p = argparse.ArgumentParser(
        prog="agent-send",
        description="Send a command to a local or connected AgentRelay agent.",
    )
    p.add_argument("--config", type=Path, default=DEFAULT_CONFIG)
    p.add_argument("--list", action="store_true",
                   help="list discovered peers and exit")
    p.add_argument("target", nargs="?", help="target node or agent@node")
    p.add_argument("command", nargs="?",
                   help="natural-language request or shell command")
    p.add_argument("--agent",
                   help="hand to a specific local agent on the target")
    grp = p.add_mutually_exclusive_group()
    grp.add_argument("--auto", action="store_const", dest="hint",
                     const="auto",
                     help="ask target to auto-execute as shell")
    grp.add_argument("--approve", action="store_const", dest="hint",
                     const="approve",
                     help="force the user-approval dialog on target")
    grp.add_argument("--reject", action="store_const", dest="hint",
                     const="reject", help="(test) ask target to reject")
    p.add_argument("--profile", choices=("safe", "project_write", "full_auto"),
                   default="safe",
                   help="permission profile recorded with the task (default: safe)")
    p.add_argument("--broadcast", action="store_true",
                   help="send to all discovered peers (no synthesis)")
    p.add_argument("--local", action="store_true",
                   help="coordinate multiple agents on this computer")
    p.add_argument("--agents",
                   help="comma-separated agents for --local, e.g. claude,codex")
    p.add_argument("--coordinator-agent",
                   help="local agent to synthesize --local results")
    p.add_argument("--mode", choices=("parallel", "sequential"), default="parallel",
                   help="coordination mode for --local")
    args = p.parse_args()

    cfg_data = load_config(args.config)
    token = cfg_data.get("token")
    if not token:
        print("no token in config", file=sys.stderr)
        sys.exit(1)
    node_name = cfg_data.get("node_name") or socket.gethostname().split(".")[0]

    if args.list:
        sys.exit(asyncio.run(cmd_list(cfg=cfg_data, self_name=node_name)))

    if args.broadcast:
        if not args.command:
            p.error("command required for --broadcast")
        sys.exit(asyncio.run(cmd_broadcast(
            token, args.command, args.agent, self_name=node_name,
            cfg=cfg_data)))

    if args.local:
        if not args.command:
            p.error("command required for --local")
        agents = parse_agents_csv(args.agents or "")
        if not agents:
            p.error("--agents is required for --local")
        sys.exit(asyncio.run(cmd_coordinate_local(
            token, args.command, agents, args.coordinator_agent,
            args.mode, cfg_data)))

    if not args.target or not args.command:
        p.error("target and command required (or use --list)")

    try:
        target, agent = parse_target(args.target, args.agent)
    except ValueError as e:
        p.error(str(e))

    sys.exit(asyncio.run(cmd_send(
        token, target, args.command, agent, args.hint, cfg_data,
        self_name=node_name, profile=args.profile)))


if __name__ == "__main__":
    main()
